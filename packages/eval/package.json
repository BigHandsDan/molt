{
  "name": "@molt/eval",
  "version": "0.1.0",
  "description": "Agent evaluation engine — metrics, regression detection, and release gating for AI agent systems",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "molteval": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai-agents",
    "evaluation",
    "metrics",
    "regression",
    "release-gate",
    "adversarial-testing",
    "molt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BigHandsDan/molt.git",
    "directory": "packages/eval"
  },
  "homepage": "https://github.com/BigHandsDan/molt/tree/main/packages/eval",
  "author": "BigHandsDan",
  "license": "Apache-2.0",
  "dependencies": {
    "@molt/mesh": "*",
    "@molt/permit": "*",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
