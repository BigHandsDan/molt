{
  "name": "@molt/mesh",
  "version": "0.1.0",
  "description": "Neutral agent interoperability bus and control plane for heterogeneous agent systems",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx demo/scenario.ts",
    "demo:full": "tsx demo/full-demo.ts",
    "demo:federation": "tsx demo/federation-demo.ts",
    "demo:exchange": "tsx demo/exchange-demo.ts",
    "demo:all": "tsx demo/full-demo.ts && tsx demo/federation-demo.ts && tsx demo/exchange-demo.ts",
    "demo:server": "tsx demo/server.ts",
    "lint": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'demo/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'demo/**/*.ts'",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "interoperability",
    "mesh",
    "bus",
    "control-plane",
    "multi-agent",
    "molt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BigHandsDan/molt.git",
    "directory": "packages/mesh"
  },
  "homepage": "https://github.com/BigHandsDan/molt/tree/main/packages/mesh",
  "author": "BigHandsDan",
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.12.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^25.9.1",
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
