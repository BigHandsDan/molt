{
  "name": "@molt/permit",
  "version": "0.1.0",
  "description": "Permissions and policy control plane for autonomous AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "moltpermit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "policies"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/index.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "permissions",
    "policy-engine",
    "cedar",
    "mcp",
    "authorization",
    "audit-logging",
    "molt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BigHandsDan/molt.git",
    "directory": "packages/permit"
  },
  "homepage": "https://github.com/BigHandsDan/molt/tree/main/packages/permit",
  "author": "BigHandsDan",
  "license": "Apache-2.0",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^25.9.1",
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
