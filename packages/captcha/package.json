{
  "name": "@molt/captcha",
  "version": "1.0.0",
  "description": "Reverse CAPTCHA for AI agent verification — SMHL challenge engine",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "bin": {
    "moltcaptcha": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx src/server/standalone.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai-agents",
    "captcha",
    "verification",
    "reverse-captcha",
    "smhl",
    "molt"
  ],
  "author": "BigHandsDan",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BigHandsDan/molt.git",
    "directory": "packages/captcha"
  },
  "homepage": "https://github.com/BigHandsDan/molt/tree/main/packages/captcha",
  "peerDependencies": {
    "express": "^4.22.2"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
